# ============================================
# MANJU WEB AGENCY - BACKEND CONFIGURATION EXAMPLE
# ============================================

# --- MongoDB Database ---
# Example: mongodb+srv://username:password@cluster0.mongodb.net/agency_db
MONGODB_URI=mongodb://127.0.0.1:27017/portfolio_db

# --- JWT Authentication ---
JWT_SECRET=your_jwt_secret_key_here

# --- Admin Credentials Configuration ---
# Set these to configure your custom admin username and password
ADMIN_USER=admin
ADMIN_PASS=admin123

# --- SMTP Email Notifications ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# --- Server Port ---
PORT=5000
